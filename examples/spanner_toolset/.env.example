# LLM Provider (required)
GOOGLE_API_KEY=your-google-api-key

# Cloud Spanner (optional — enables live mode)
# Set all three to run real Spanner queries.
# Also ensure Application Default Credentials are configured:
#   gcloud auth application-default login
# SPANNER_PROJECT_ID=your-gcp-project-id
# SPANNER_INSTANCE_ID=your-spanner-instance-id
# SPANNER_DATABASE_ID=your-spanner-database-id
