# Required: Your OpenAI API key
OPENAI_API_KEY=sk-...

# Optional: Polling interval in seconds (default: 10)
# Deep research takes longer, so a higher interval is recommended
POLL_INTERVAL_SECS=10

# Optional: Deep research model (default: o3-deep-research)
# Available models: o3-deep-research, o4-mini-deep-research
DEEP_RESEARCH_MODEL=o3-deep-research
