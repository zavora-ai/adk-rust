# LLM Provider (required)
GOOGLE_API_KEY=your-google-api-key

# Slack Bot Token (optional — enables live mode)
# Create a Slack app at https://api.slack.com/apps and install it to your workspace.
# Required scopes: chat:write, channels:history, reactions:write
# SLACK_BOT_TOKEN=xoxb-your-bot-token

# Target Slack channel (optional, defaults to #general)
# SLACK_CHANNEL=#your-channel
